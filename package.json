{
  "name": "image-cropping-library",
  "version": "1.0.0",
  "description": "A React TypeScript library for image cropping functionality with drag and drop support",
  "author": "Your Name <your.email@example.com>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "dist/style.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run build:types && npm run build:lib",
    "build:lib": "vite build",
    "build:types": "tsc --project tsconfig.build.json",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "prepublishOnly": "npm run build",
    "demo": "cd demo && npm run dev",
    "demo:build": "cd demo && npm run build",
    "demo:install": "cd demo && npm install"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sass": "^1.69.5",
    "typescript": "^5.2.2",
    "vite": "^5.0.8"
  },
  "keywords": [
    "react",
    "typescript",
    "image",
    "cropping",
    "editor",
    "library"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/image-cropping-library.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/image-cropping-library/issues"
  },
  "homepage": "https://github.com/yourusername/image-cropping-library#readme"
}